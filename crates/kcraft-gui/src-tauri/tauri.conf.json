{
  "productName": "KCraft",
  "version": "1.0.0",
  "identifier": "org.kcraft.launcher",
  "build": {
    "frontendDist": "../frontend/.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../frontend && npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "KCraft",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "UPDATE_PUBKEY_HERE",
      "endpoints": [
        "https://github.com/kcraft-org/kcraft/releases/latest/download/latest.json"
      ]
    }
  }
}
