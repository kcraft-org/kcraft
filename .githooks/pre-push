#!/usr/bin/env bash
# Pre-push hook: validate tag names before pushing
# Tags must follow semver: v<major>.<minor>.<patch>[-<prerelease><number>]
# e.g., v1.0.0, v1.0.0-rc1, v2.3.4-beta2
# Rejects tags that don't match the expected format.

remote="$1"
url="$2"

while read local_ref local_oid remote_ref remote_oid; do
  # Only validate tags
  if [[ "$remote_ref" == refs/tags/* ]]; then
    tag="${remote_ref#refs/tags/}"

    # Validate tag format: vX.Y.Z or vX.Y.Z-<word><number>
    if ! echo "$tag" | grep -Eq '^v[0-9]+\.[0-9]+\.[0-9]+(-[a-zA-Z]+[0-9]+)?$'; then
      echo ""
      echo "ERROR: Invalid tag name '$tag'"
      echo "  Tag names must follow semver format: v<major>.<minor>.<patch>[-<prerelease><number>]"
      echo "  Examples: v1.0.0, v1.0.0-rc1, v2.3.4-beta2"
      echo "  Push rejected."
      echo ""
      exit 1
    fi
  fi
done

exit 0
